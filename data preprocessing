ukb[] <- lapply(ukb, function(x) {
  if (is.character(x) || is.factor(x)) {
    x[x == "Do not know"] <- NA
  }
  x
})

sum(sapply(ukb, function(x) {
  if (is.factor(x)) x <- as.character(x)
  if (is.character(x)) sum(x == "Do not know", na.rm = TRUE) else 0
}))



#'prefer not to answer' rate calculation
pna_rate_nonNA <- sapply(ukb_cvd_2, function(x) {
  if (is.character(x) || is.factor(x)) {
    mean(as.character(x) == "Prefer not to answer", na.rm = TRUE)  
  } else NA_real_
})
pna_nonNA <- data.frame(
  column = names(pna_rate_nonNA),
  pna_rate = as.numeric(pna_rate_nonNA),
  row.names = NULL
)


N <- nrow(ukb_cvd_2)
pna_rate <- sapply(ukb_cvd_2, function(x) {
  if (is.character(x) || is.factor(x)) {
    sum(as.character(x) == "Prefer not to answer", na.rm = TRUE) / N
  } else {
    NA_real_
  }
})
pna_df <- data.frame(
  column = names(pna_rate),
  pna_rate = as.numeric(pna_rate),
  row.names = NULL
)
pna_df <- pna_df[order(-pna_df$pna_rate), ]


merged_pna <- merge(
  pna_df,
  pna_nonNA,
  by = "column",
  all = TRUE,
  suffixes = c("_totalN", "_nonNA")
)

names(merged_pna)[names(merged_pna) == "pna_rate_totalN"] <- "pna_rate_overallN"
names(merged_pna)[names(merged_pna) == "pna_rate_nonNA"]  <- "pna_rate_among_nonmissing"
saveRDS(
  merged_pna,
  file = "/rds/general/project/hda_25-26/live/TDS/TDS_Group8/extraction_and_recoding/merged_pna.rds"
)


#Step 1. Drop non-informative variables. 
#First, drop variables that contain only “Prefer not to answer” and/or NA
vars_drop <- merged_pna$column[
  !is.na(merged_pna$pna_rate_among_nonmissing) &
    merged_pna$pna_rate_among_nonmissing == 1
]
ukb_cvd_2[, (vars_drop) := NULL] #exclude 27 variables

#Step 2. Recode very rare PNA as missing. 
#For variables where pna_rate_overallN < 1%, we recode “Prefer not to answer” as NA. 
vars_small_pna <- merged_pna$column[
  !is.na(merged_pna$pna_rate_overallN) &
    merged_pna$pna_rate_overallN < 0.01 & merged_pna$pna_rate_overallN > 0
]
vars_small_pna <- setdiff(vars_small_pna, vars_drop)
ukb_cvd_2[, (vars_small_pna) := lapply(.SD, function(x) {
  x[as.character(x) == "Prefer not to answer"] <- NA
  x
}), .SDcols = vars_small_pna]
